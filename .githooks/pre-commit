#!/bin/sh
# Block accidentally staging dependency / build output folders (allows *removing* them from Git).
if git diff --cached --name-only --diff-filter=AM | grep -E '(^|/)node_modules/|(^|/)\.next/'; then
  echo ""
  echo "Commit blocked: do not commit node_modules or .next"
  echo "Fix: git rm -r --cached frontend/node_modules backend/node_modules frontend/.next"
  echo ""
  exit 1
fi
exit 0
