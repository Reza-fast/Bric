PORT=4000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/bric
NODE_ENV=development

# Required in production (min 32 chars). Dev fallback exists only when NODE_ENV is not production.
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars
JWT_EXPIRES_IN=7d
AUTH_COOKIE_NAME=bric_token

# Comma-separated browser origins allowed to send cookies (CORS)
FRONTEND_ORIGIN=http://localhost:3000

# Optional
BCRYPT_ROUNDS=12
